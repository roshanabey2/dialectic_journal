<div class="grid h-full min-h-[calc(100vh-8rem)] gap-6 xl:grid-cols-[minmax(0,2fr)_minmax(20rem,1fr)]">
  <section class="min-w-0 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
      <div>
        <h2 class="text-lg font-semibold text-slate-900">Dialogue</h2>
        <p class="text-sm text-slate-500">Live structuring</p>
      </div>
    </div>

    <div class="flex h-[calc(100%-4.5rem)] min-h-[32rem] flex-col" data-controller="conversation">
      <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-6 py-5" data-conversation-target="messages">
        <!-- Messages from Talker agent will appear here -->
      </div>

      <form class="border-t border-slate-200 bg-slate-50 p-4" data-action="submit->conversation#submitMessage">
        <div class="flex items-center gap-3">
          <input
            type="text"
            class="min-w-0 flex-1 rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-500 focus:ring-2 focus:ring-slate-200"
            placeholder="Type your message..."
            data-conversation-target="input"
            data-action="keydown->conversation#sendMessage"
          >
          <button name="button" type="submit" class="inline-flex shrink-0 items-center justify-center rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-700">
            Send
          </button>
        </div>
      </form>
    </div>
  </section>

  <aside class="min-w-0 rounded-2xl border border-slate-200 bg-white shadow-sm" data-conversation-target="notesPanel" hidden>
    <div class="border-b border-slate-200 px-6 py-4">
      <h3 class="text-lg font-semibold text-slate-900">Structured Notes</h3>
    </div>
    <div class="prose max-w-none overflow-y-auto px-6 py-5 text-slate-700" data-conversation-target="notesContent">
      <!-- Rich formatted notes from Structurer agent will appear here -->
    </div>
  </aside>
</div>
